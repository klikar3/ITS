<?php

namespace app\controllers;

use Yii;
use yii\helpers\Arrayhelper;
use yii\helpers\Html;
use yii\helpers\Url;
use yii\web\Controller;
use yii\web\NotFoundHttpException;
use yii\filters\VerbFilter;

use app\models\RzReport;
use app\models\RzReportSearch;

/**
 * RzReportController implements the CRUD actions for RzReport model.
 */
class RzReportController extends Controller
{
    /**
     * @inheritdoc
     */
    public function behaviors()
    {
        return [
            'verbs' => [
                'class' => VerbFilter::className(),
                'actions' => [
                    'delete' => ['POST'],
                ],
            ],
        ];
    }

    /**
     * Lists all RzReport models.
     * @return mixed
     */
    public function actionIndex()
    {
//        $rzSysteme = ArrayHelper::map(\app\models\RzSysteme::find()->asArray()->all(), 'System', 'System');
        $rzSysteme = ArrayHelper::map(\app\models\RzSysteme::find()->orderBy('System')->all(), 'System', 'System');
        $rzKunden = ArrayHelper::map(\app\models\RzKunden::find()->orderBy('Kunde')->all(), 'Kunde', 'Kunde');
        $rzStandorte = ArrayHelper::map(\app\models\RzStandorte::find()->orderBy('Standort')->all(), 'Standort', 'Standort');
//        Yii::Warning(\yii\helpers\VarDumper::dumpAsString($rzKunden, 10, false),'application');   

        $searchModel = new RzReportSearch();
        $dataProvider = $searchModel->search(Yii::$app->request->queryParams);

        return $this->render('index', [
            'searchModel' => $searchModel,
            'dataProvider' => $dataProvider, 
            'rzSysteme' => $rzSysteme, 
            'rzKunden' => $rzKunden, 
            'rzStandorte' => $rzStandorte,
        ]);
    }

    /**
     * Displays a single RzReport model.
     * @param string $id
     * @return mixed
     * @throws NotFoundHttpException if the model cannot be found
     */
    public function actionView($id)
    {
        return $this->render('view', [
            'model' => $this->findModel($id),
        ]);
    }

    /**
     * Creates a new RzReport model.
     * If creation is successful, the browser will be redirected to the 'view' page.
     * @return mixed
     */
    public function actionCreate()
    {
        $rzSysteme = ArrayHelper::map(\app\models\RzSysteme::find()->orderBy('System')->all(), 'System', 'System');
        $rzKunden = ArrayHelper::map(\app\models\RzKunden::find()->orderBy('Kunde')->all(), 'Kunde', 'Kunde');
        $rzStandorte = ArrayHelper::map(\app\models\RzStandorte::find()->orderBy('Standort')->all(), 'Standort', 'Standort');

        $model = new RzReport();
        
        // Defaults setzen:
        $model->von = date('Y-m-d H:i:s.u');
        $model->bis = date('Y-m-d H:i:s.u', strtotime('1 hour'));
        $model->von_ausw = date('Y-m-d H:i:s.u');
        $model->bis_ausw = date('Y-m-d H:i:s.u', strtotime('1 hour'));
        $model->Author=$_SERVER['AUTH_USER'];
//        Yii::Warning(\yii\helpers\VarDumper::dumpAsString($_SERVER['AUTH_USER'], 10, false),'application');   
//        $model->Korrektor=$_SERVER['AUTH_USER'];

        if ($model->load(Yii::$app->request->post())) {
            $model->System = is_array($model->System)?implode(',',$model->System):$model->System;
            $model->Kunde = is_array($model->Kunde)?implode(',',$model->Kunde):$model->Kunde;
            $model->Betroffen = is_array($model->Betroffen)?implode(',',$model->Betroffen):$model->Betroffen;
            $model->Standort = is_array($model->Standort)?implode(',',$model->Standort):$model->Standort;
            $model->Author=$_SERVER['AUTH_USER'];
//            $model->Korrektor=$_SERVER['AUTH_USER'];
            $model->von = substr($model->von,0,23);
            $model->bis = substr($model->bis,0,23);
            $model->von_ausw = substr($model->von_ausw,0,23);
            $model->bis_ausw = substr($model->bis_ausw,0,23);
            if ($model->save()) {
              return $this->redirect(['view', 'id' => $model->Rid]);
            }
        }


        return $this->render('create', [
            'model' => $model,
            'rzSysteme' => $rzSysteme, 
            'rzKunden' => $rzKunden, 
            'rzStandorte' => $rzStandorte,
        ]);
    }

    /**
     * Updates an existing RzReport model.
     * If update is successful, the browser will be redirected to the 'view' page.
     * @param string $id
     * @return mixed
     * @throws NotFoundHttpException if the model cannot be found
     */
    public function actionUpdate($id)
    {
        $model = $this->findModel($id);

        if ($model->load(Yii::$app->request->post())){ 
        Yii::Warning('load','application');
//            $model->Kunde = implode (", ",$model->Kunde);
   
            $model->System = is_array($model->System)?implode(',',$model->System):$model->System;
            $model->Kunde = is_array($model->Kunde)?implode(',',$model->Kunde):$model->Kunde;
            $model->Betroffen = is_array($model->Betroffen)?implode(',',$model->Betroffen):$model->Betroffen;
            $model->Standort = is_array($model->Standort)?implode(',',$model->Standort):$model->Standort;
            $model->Korrektor=$_SERVER['AUTH_USER'];
//            $d = \DateTime::createFromFormat('php:Y-m-d H:i:s.u',substr($model->von,0,23));
//        Yii::Warning(\DateTime::getLastErrors(),'application');   
//        Yii::Warning(substr($model->von,0,23),'application');   
//        Yii::Warning($d,'application');   
            $model->von = substr($model->von,0,23);
            $model->bis = substr($model->bis,0,23);
            $model->von_ausw = substr($model->von_ausw,0,23);
            $model->bis_ausw = substr($model->bis_ausw,0,23);
            if ($model->validate()) {  
                $model->von = str_replace("-","", $model->von);
                $model->bis = str_replace("-","", $model->bis);
                $model->von_ausw = str_replace("-","", $model->von_ausw);
                $model->bis_ausw = str_replace("-","", $model->bis_ausw);
                Yii::Warning($model->von,'application');
                $model->scenario = "save";
                if ($model->save()) {
                  Yii::Warning('save','application');   
                  return $this->redirect(['view', 'id' => $model->Rid]);
                } else {
                  Yii::Warning('no save','application');   
                } 
            } else {
                Yii::Warning('no validate','application');   
            }
            
        }

        Yii::Warning('no load', 'application');   
        $rzSysteme = ArrayHelper::map(\app\models\RzSysteme::find()->orderBy('System')->all(), 'System', 'System');
        $rzKunden = ArrayHelper::map(\app\models\RzKunden::find()->orderBy('Kunde')->all(), 'Kunde', 'Kunde');
        $rzStandorte = ArrayHelper::map(\app\models\RzStandorte::find()->orderBy('Standort')->all(), 'Standort', 'Standort');
        $model->System = is_array($model->System)?implode(',',$model->System):$model->System;
        $model->Kunde = is_array($model->Kunde)?implode(',',$model->Kunde):$model->Kunde;
        $model->Betroffen = is_array($model->Betroffen)?implode(',',$model->Betroffen):$model->Betroffen;
        $model->Standort = is_array($model->Standort)?implode(',',$model->Standort):$model->Standort;

        return $this->render('update', [
            'model' => $model,
            'rzSysteme' => $rzSysteme, 
            'rzKunden' => $rzKunden, 
            'rzStandorte' => $rzStandorte,
        ]);
    }

    /**
     * Deletes an existing RzReport model.
     * If deletion is successful, the browser will be redirected to the 'index' page.
     * @param string $id
     * @return mixed
     * @throws NotFoundHttpException if the model cannot be found
     */
    public function actionDelete($id)
    {
        $this->findModel($id)->delete();

        return $this->redirect(['index']);
    }

    /**
     * Finds the RzReport model based on its primary key value.
     * If the model is not found, a 404 HTTP exception will be thrown.
     * @param string $id
     * @return RzReport the loaded model
     * @throws NotFoundHttpException if the model cannot be found
     */
    protected function findModel($id)
    {
        if (($model = RzReport::findOne($id)) !== null) {
            return $model;
        }

        throw new NotFoundHttpException(Yii::t('app', 'The requested page does not exist.'));
    }
}
